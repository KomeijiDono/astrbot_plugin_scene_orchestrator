{
  "general": {
    "description": "基础设置",
    "type": "object",
    "hint": "控制插件是否启用以及运行模式。",
    "items": {
      "enabled": {
        "description": "启用",
        "type": "bool",
        "default": true,
        "hint": "关闭后插件不接管消息，也不注入场景上下文。"
      },
      "mode": {
        "description": "运行模式",
        "type": "string",
        "default": "takeover",
        "options": ["takeover", "inject", "director_gate"],
        "hint": "takeover=插件生成并发送角色回复；inject=只向原生 LLM 请求追加场景上下文；director_gate=原生 LLM 剧情/分幕演出模式。"
      },
      "debug_mode": {
        "description": "调试日志",
        "type": "bool",
        "default": false,
        "hint": "开启后输出状态注入、接力和调试信息。"
      }
    }
  },
  "scene": {
    "description": "场景设置",
    "type": "object",
    "hint": "控制剧情推进和世界状态历史。",
    "items": {
      "enable_auto_scene": {
        "description": "自动推进场景",
        "type": "bool",
        "default": true,
        "hint": "允许导演状态根据对话推进剧情场景。"
      },
      "max_events": {
        "description": "最大事件数",
        "type": "int",
        "default": 100,
        "hint": "世界状态中最多保留的历史事件数量。",
        "slider": {"min": 1, "max": 1000, "step": 1}
      }
    }
  },
  "state": {
    "description": "状态隔离",
    "type": "object",
    "hint": "控制世界状态隔离粒度。",
    "items": {
      "scope": {
        "description": "状态范围",
        "type": "string",
        "default": "origin",
        "options": ["origin", "global"],
        "hint": "origin=每个 unified_msg_origin 单独保存；global=所有来源共享。director_gate 群聊按 group_id 共享。"
      }
    }
  },
  "director": {
    "description": "兼容设置",
    "type": "object",
    "hint": "保留旧配置字段以兼容已有配置。",
    "items": {
      "speech_plan_ttl_seconds": {
        "description": "旧发言计划有效期",
        "type": "int",
        "default": 120,
        "hint": "兼容旧版本字段。新 director_gate 模式不会使用该值。",
        "slider": {"min": 10, "max": 600, "step": 10}
      },
      "default_reply_style": {
        "description": "旧默认回复长度",
        "type": "string",
        "default": "normal",
        "options": ["short", "normal", "long"],
        "hint": "兼容旧版本字段。新 director_gate 模式不会使用该值。"
      }
    }
  },
  "worldbook": {
    "description": "世界观",
    "type": "object",
    "hint": "用户可编辑的全局世界观，会注入原生 AstrBot LLM 请求。",
    "items": {
      "enabled": {
        "description": "启用世界观",
        "type": "bool",
        "default": true,
        "hint": "开启后读取 worldbook 文件作为剧情背景。"
      },
      "path": {
        "description": "世界观文件路径",
        "type": "string",
        "default": "data/worldbook.md",
        "hint": "相对路径基于插件目录；也可以填写绝对路径。"
      },
      "max_chars": {
        "description": "最大读取字符数",
        "type": "int",
        "default": 6000,
        "hint": "限制注入 prompt 的世界观长度。",
        "slider": {"min": 0, "max": 30000, "step": 500}
      },
      "auto_create": {
        "description": "自动创建模板",
        "type": "bool",
        "default": true,
        "hint": "世界观文件不存在时自动创建模板。"
      }
    }
  },
  "dialogue": {
    "description": "对话接力",
    "type": "object",
    "hint": "兼容旧 #对话X 手动接力。",
    "items": {
      "enabled": {
        "description": "启用对话接力",
        "type": "bool",
        "default": false,
        "hint": "开启后识别类似 @机器人A #对话B 的消息。"
      },
      "handoff_delay_seconds": {
        "description": "接力延迟秒数",
        "type": "int",
        "default": 2,
        "hint": "A 回复后等待多少秒再 @B。",
        "slider": {"min": 0, "max": 30, "step": 1}
      },
      "cooldown_seconds": {
        "description": "接力冷却秒数",
        "type": "int",
        "default": 10,
        "hint": "同一群两次自动接力之间的最小间隔。",
        "slider": {"min": 0, "max": 300, "step": 5}
      },
      "targets": {
        "description": "目标映射",
        "type": "object",
        "default": {},
        "hint": "键是 #对话 后面的名字，例如 B；值包含 bot_id、mention_id、display_name。",
        "items": {}
      },
      "targets_json": {
        "description": "目标映射 JSON",
        "type": "string",
        "default": "",
        "hint": "如果上面的对象配置被面板清空，请在这里填写 JSON。"
      }
    }
  },
  "performance": {
    "description": "分幕演出",
    "type": "object",
    "hint": "用 #开演/#继续 启动专门导演 LLM，按固定轮次自动 @ 角色演出。",
    "items": {
      "enabled": {
        "description": "启用分幕演出",
        "type": "bool",
        "default": true,
        "hint": "开启后识别 #开演、#继续、#暂停、#重开、#剧情。"
      },
      "default_rounds": {
        "description": "默认轮次",
        "type": "int",
        "default": 4,
        "hint": "用户未指定轮次时自动对话多少个角色回合。",
        "slider": {"min": 1, "max": 20, "step": 1}
      },
      "max_rounds": {
        "description": "最大轮次",
        "type": "int",
        "default": 10,
        "hint": "限制用户指定的最大自动回合数，防止无限接力。",
        "slider": {"min": 1, "max": 50, "step": 1}
      },
      "handoff_delay_seconds": {
        "description": "演出接力延迟秒数",
        "type": "int",
        "default": 2,
        "hint": "每次角色回复后等待多少秒再 @ 下一位。",
        "slider": {"min": 0, "max": 30, "step": 1}
      },
      "director_provider_id": {
        "description": "导演 Provider ID",
        "type": "string",
        "default": "",
        "hint": "预留字段。为空时使用当前 AstrBot 默认 provider。"
      },
      "director_model": {
        "description": "导演模型名",
        "type": "string",
        "default": "",
        "hint": "预留字段。为空时使用 provider 默认模型。"
      },
      "auto_pause_after_rounds": {
        "description": "轮次结束后暂停",
        "type": "bool",
        "default": true,
        "hint": "达到轮次后停止自动 @，等待用户用 #继续 给新指示。"
      }
    }
  },
  "persona": {
    "description": "人格继承",
    "type": "object",
    "hint": "控制 takeover 模式是否继承 AstrBot 当前会话人格。",
    "items": {
      "inherit_astrbot_persona": {
        "description": "继承 AstrBot 人格",
        "type": "bool",
        "default": true,
        "hint": "开启后 takeover 模式会注入当前会话机器人的 AstrBot 人格设定。"
      },
      "debug_persona_resolution": {
        "description": "人格解析日志",
        "type": "bool",
        "default": false,
        "hint": "开启后输出当前消息解析到的人格来源和人格 ID。"
      }
    }
  },
  "llm": {
    "description": "LLM 设置",
    "type": "object",
    "hint": "控制 JSON 解析策略。",
    "items": {
      "strict_json": {
        "description": "严格 JSON",
        "type": "bool",
        "default": true,
        "hint": "开启后导演输出无法解析为 JSON 时使用安全回退策略。"
      }
    }
  },
  "roles": {
    "description": "角色设置",
    "type": "object",
    "hint": "控制 takeover 模式角色选择的默认值。",
    "items": {
      "default_role": {
        "description": "默认角色",
        "type": "string",
        "default": "anon_default",
        "hint": "导演没有指定角色且规则无法判断时使用的角色 ID。"
      }
    }
  }
}
