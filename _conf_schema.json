{
  "general": {
    "description": "基础设置",
    "type": "object",
    "hint": "控制导演插件是否启用以及使用接管回复还是注入上下文模式。",
    "items": {
      "enabled": {
        "description": "启用",
        "type": "bool",
        "default": true,
        "hint": "关闭后插件不会接管消息，也不会注入场景上下文。"
      },
      "mode": {
        "description": "运行模式",
        "type": "string",
        "default": "takeover",
        "options": [
          "takeover",
          "inject",
          "director_gate"
        ],
        "hint": "takeover=插件生成并发送角色回复；inject=只向原生 LLM 请求追加场景上下文；director_gate=多机器人主导演门控，推荐用于多个适配器实例。"
      },
      "debug_mode": {
        "description": "调试日志",
        "type": "bool",
        "default": false,
        "hint": "开启后输出导演决策和注入动作日志。"
      }
    }
  },
  "scene": {
    "description": "场景设置",
    "type": "object",
    "hint": "控制剧情推进和世界状态历史。",
    "items": {
      "enable_auto_scene": {
        "description": "自动推进场景",
        "type": "bool",
        "default": true,
        "hint": "允许导演根据用户输入推进剧情场景。"
      },
      "max_events": {
        "description": "最大事件数",
        "type": "int",
        "default": 100,
        "hint": "世界状态中最多保留的历史事件数量。",
        "slider": {
          "min": 1,
          "max": 1000,
          "step": 1
        }
      }
    }
  },
  "state": {
    "description": "状态隔离",
    "type": "object",
    "hint": "控制导演插件的世界状态隔离粒度。",
    "items": {
      "scope": {
        "description": "状态范围",
        "type": "string",
        "default": "origin",
        "options": [
          "origin",
          "global"
        ],
        "hint": "origin=每个 unified_msg_origin 单独保存剧情状态；global=所有来源共享状态。"
      }
    }
  },
  "director": {
    "description": "主导演设置",
    "type": "object",
    "hint": "控制 director_gate 模式的发言计划和回复风格。",
    "items": {
      "speech_plan_ttl_seconds": {
        "description": "发言计划有效期",
        "type": "int",
        "default": 120,
        "hint": "同一条消息的导演发言计划保留多少秒，避免多个机器人重复生成计划。",
        "slider": {
          "min": 10,
          "max": 600,
          "step": 10
        }
      },
      "default_reply_style": {
        "description": "默认回复长度",
        "type": "string",
        "default": "normal",
        "options": [
          "short",
          "normal",
          "long"
        ],
        "hint": "导演没有指定回复长度时使用的默认值。"
      }
    }
  },
  "worldbook": {
    "description": "世界观",
    "type": "object",
    "hint": "用户可编辑的全局世界观，供导演生成发言计划时参考。最终回复仍走 AstrBot 原生人格和知识库链路。",
    "items": {
      "enabled": {
        "description": "启用世界观",
        "type": "bool",
        "default": true,
        "hint": "开启后导演会读取 worldbook 文件作为角色扮演背景。"
      },
      "path": {
        "description": "世界观文件路径",
        "type": "string",
        "default": "data/worldbook.md",
        "hint": "相对路径基于插件目录；也可以填写绝对路径。"
      },
      "max_chars": {
        "description": "最大读取字符数",
        "type": "int",
        "default": 6000,
        "hint": "限制注入导演 prompt 的世界观长度，避免提示词过长。",
        "slider": {
          "min": 0,
          "max": 30000,
          "step": 500
        }
      },
      "auto_create": {
        "description": "自动创建模板",
        "type": "bool",
        "default": true,
        "hint": "世界观文件不存在时自动创建一个可编辑模板。"
      }
    }
  },
  "persona": {
    "description": "人格继承",
    "type": "object",
    "hint": "控制 takeover 模式是否继承 AstrBot 当前会话人格。",
    "items": {
      "inherit_astrbot_persona": {
        "description": "继承 AstrBot 人格",
        "type": "bool",
        "default": true,
        "hint": "开启后，导演决策和角色回复会注入当前会话/机器人的 AstrBot 人格设定。"
      },
      "debug_persona_resolution": {
        "description": "人格解析日志",
        "type": "bool",
        "default": false,
        "hint": "开启后输出当前消息解析到的人格来源和人格 ID。"
      }
    }
  },
  "llm": {
    "description": "LLM 设置",
    "type": "object",
    "hint": "控制导演决策解析策略。",
    "items": {
      "strict_json": {
        "description": "严格 JSON",
        "type": "bool",
        "default": true,
        "hint": "开启后导演输出无法解析为 JSON 时会使用安全回退决策。"
      }
    }
  },
  "roles": {
    "description": "角色设置",
    "type": "object",
    "hint": "控制角色选择的默认值。",
    "items": {
      "default_role": {
        "description": "默认角色",
        "type": "string",
        "default": "anon_default",
        "hint": "导演没有指定角色且规则无法判断时使用的角色 ID。"
      }
    }
  }
}
